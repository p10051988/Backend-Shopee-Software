# ============================================================
# Auto-Shopee Environment Configuration
# Copy file nay thanh .env roi dien gia tri that
# KHONG commit .env len git
# ============================================================

# --- Public backend URL used by desktop ---
BACKEND_URL=http://127.0.0.1:8000
CUSTOMER_PORTAL_URL=https://your-website.example.com

# --- Hybrid Go backend bind/runtime ---
BACKEND_BIND=0.0.0.0:8000
DATABASE_URL=postgresql://autoshopee:CHANGE_ME@localhost:5432/autoshopee?sslmode=disable
# Local/dev SQLite example:
# DATABASE_URL=sqlite:///ABSOLUTE_PATH_TO_Backend/sql_app.db

# --- Python sidecar used for password hashing + secure module packaging ---
BACKEND_PY_SIDECAR_HOST=127.0.0.1
BACKEND_PY_SIDECAR_PORT=9801
BACKEND_PY_SIDECAR_URL=http://127.0.0.1:9801

# --- Internal API (website/admin -> backend bridge) ---
INTERNAL_API_SECRET=CHANGE_ME_BEFORE_DEPLOY
MASTER_KEY=CHANGE_ME_BEFORE_DEPLOY
RELEASE_SIGNING_PRIVATE_KEY=GENERATE_WITH_py_-3.11_generate_release_signing_keypair.py

# --- Runtime guards ---
DEV_MODE=false
ALLOW_INSECURE_DEFAULTS=false
WORKER_METRICS_ENABLED=true
RUNTIME_METRICS_DIR=logs/runtime-metrics
RUNTIME_METRICS_RETENTION_DAYS=90
RUNTIME_METRICS_FLUSH_SECONDS=30

# --- Terminal monitor / alert watcher ---
BACKEND_MONITOR_TIMEOUT_SECONDS=10
BACKEND_ALERT_POLL_SECONDS=60
BACKEND_ALERT_COOLDOWN_SECONDS=900
BACKEND_ALERT_ERROR_RATE_PERCENT=5
BACKEND_ALERT_P95_MS=1500
BACKEND_ALERT_AVG_MS=700
BACKEND_ALERT_CPU_PERCENT=85
BACKEND_ALERT_MEM_AVAILABLE_MB=200
BACKEND_ALERT_DISK_PERCENT=90
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
