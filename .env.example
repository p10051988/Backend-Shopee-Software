# ============================================================
# Auto-Shopee Environment Configuration
# Sao chép file này thành .env và điền giá trị thật
# KHÔNG commit .env lên git!
# ============================================================

# --- Backend Server ---
# URL backend server (đổi thành domain khi deploy VPS)
BACKEND_URL=http://127.0.0.1:8000
BACKEND_BIND=0.0.0.0:8000
BACKEND_WORKERS=2
CUSTOMER_PORTAL_URL=https://your-website.example.com
DATABASE_URL=sqlite:///ABSOLUTE_PATH_TO_Backend/sql_app.db
# PostgreSQL production example:
# DATABASE_URL=postgresql://autoshopee:CHANGE_ME@127.0.0.1:5432/autoshopee
GUNICORN_PID_FILE=gunicorn.pid
WORKER_METRICS_DIR=Backend/runtime/worker_metrics
WORKER_METRICS_ENABLED=true
WORKER_METRICS_FLUSH_SECONDS=2

# --- Internal API (PHP <-> Python bridge) ---
# Secret shared giữa web PHP, seed scripts và Python backend
# Dùng để ký HMAC cho /api/internal/*
INTERNAL_API_SECRET=CHANGE_ME_BEFORE_DEPLOY
MASTER_KEY=CHANGE_ME_BEFORE_DEPLOY
RELEASE_SIGNING_PRIVATE_KEY=GENERATE_WITH_py_-3.11_generate_release_signing_keypair.py
DEV_MODE=false
ALLOW_INSECURE_DEFAULTS=false
